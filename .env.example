# Copy to `.env` at repo root (gitignored). The `bumblebee` CLI loads it from the repo automatically.
# Guided flow: `bumblebee setup` — docs/operations/setup-wizard.md
# Full inventory: docs/operations/env-vars.md

# IANA timezone for wall clock in prompts and get_current_time. On Railway / hybrid_railway, defaults
# to America/New_York (US Eastern) when unset. Override for other regions.
# BUMBLEBEE_TIMEZONE=

# --- Platforms ---
# Must match `token_env` in `configs/entities/<name>.yaml` when using that platform.
TELEGRAM_TOKEN=
DISCORD_TOKEN=

# --- Deployment / inference (body vs brain) ---
# Uncomment the block that matches your mode. YAML in `configs/default.yaml` can set these instead.

# Local: Ollama (or other OpenAI-compatible URL) on this machine — default stack.
# BUMBLEBEE_DEPLOYMENT_MODE=local
# BUMBLEBEE_INFERENCE_PROVIDER=local

# Hybrid: brain at home behind a tunnel; body (e.g. worker) on Railway with Postgres.
# BUMBLEBEE_DEPLOYMENT_MODE=hybrid_railway
# BUMBLEBEE_INFERENCE_PROVIDER=remote_gateway
# BUMBLEBEE_INFERENCE_BASE_URL=https://your-tunnel.example.com
# BUMBLEBEE_INFERENCE_TIMEOUT=120

# Bearer for remote gateway calls — must match `INFERENCE_GATEWAY_TOKEN` on the home gateway process.
# Default harness key name is in configs/default.yaml (`inference.api_key_env`).
BUMBLEBEE_INFERENCE_GATEWAY_TOKEN=

# Advanced: env var name that holds the gateway bearer token (default BUMBLEBEE_INFERENCE_GATEWAY_TOKEN).
# BUMBLEBEE_INFERENCE_API_KEY_ENV=

# Override Ollama URL when not using inference.base_url / remote gateway.
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Railway / Postgres (hybrid body on cloud) ---
# DATABASE_URL=postgresql://user:pass@host:5432/bumblebee

# --- Object storage for attachments (hybrid) ---
# BUMBLEBEE_ATTACHMENTS_BACKEND=object_s3_compat
# BUMBLEBEE_S3_ENDPOINT_URL=https://...
# BUMBLEBEE_S3_BUCKET=...
# BUMBLEBEE_S3_ACCESS_KEY=...
# BUMBLEBEE_S3_SECRET_KEY=...

# --- Home inference gateway (runs on home machine only) ---
# Terminate Cloudflare Tunnel (or equivalent) ONLY at this gateway (127.0.0.1:port) — never at a
# broad reverse proxy that also exposes SSH, NAS UI, or other host services.
# See docs/architecture/inference-boundary.md
INFERENCE_GATEWAY_TOKEN=
# Upstream model server (OpenAI-compatible).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Listen address for the gateway process.
# INFERENCE_GATEWAY_HOST=127.0.0.1
# INFERENCE_GATEWAY_PORT=8010
# INFERENCE_GATEWAY_BACKEND_TIMEOUT=120
# INFERENCE_GATEWAY_MAX_BODY_BYTES=8000000

# --- Optional tools ---
# Firecrawl: preferred for search_web / fetch_url when harness enables it; else ddgs / aiohttp.
FIRECRAWL_API_KEY=
# FAL_API_KEY=
# BUMBLEBEE_EXECUTION_RPC_URL=https://hands.example.com
# BUMBLEBEE_EXECUTION_RPC_TOKEN=

# --- Railway / API (see env-vars.md) ---
# BUMBLEBEE_ENTITY=canary
# BUMBLEBEE_RAILWAY_ROLE=worker
# PORT=8080
