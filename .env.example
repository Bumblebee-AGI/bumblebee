# Copy to `.env` at repo root (gitignored). Loaded automatically by `bumblebee` CLI.

# --- Platforms ---
TELEGRAM_TOKEN=
DISCORD_TOKEN=

# --- Deployment / inference (body vs brain) ---
# BUMBLEBEE_DEPLOYMENT_MODE=local
# BUMBLEBEE_DEPLOYMENT_MODE=hybrid_railway
# BUMBLEBEE_INFERENCE_PROVIDER=local
# BUMBLEBEE_INFERENCE_PROVIDER=remote_gateway
# BUMBLEBEE_INFERENCE_BASE_URL=https://your-tunnel.example.com
# BUMBLEBEE_INFERENCE_GATEWAY_TOKEN=long-random-shared-secret
# BUMBLEBEE_INFERENCE_TIMEOUT=120

# Local Ollama (full local mode)
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Railway / Postgres (hybrid body on cloud) ---
# DATABASE_URL=postgresql://user:pass@host:5432/bumblebee

# --- Object storage for attachments (hybrid) ---
# BUMBLEBEE_ATTACHMENTS_BACKEND=object_s3_compat
# BUMBLEBEE_S3_ENDPOINT_URL=https://...
# BUMBLEBEE_S3_BUCKET=...
# BUMBLEBEE_S3_ACCESS_KEY=...
# BUMBLEBEE_S3_SECRET_KEY=...

# --- Home inference gateway (runs on home machine only; Railway uses BUMBLEBEE_INFERENCE_* above) ---
# Terminate Cloudflare Tunnel (or equivalent) ONLY at this gateway (127.0.0.1:port) — never at a
# broad reverse proxy that also exposes SSH, NAS UI, or other host services. See docs/architecture/inference-boundary.md
# INFERENCE_GATEWAY_TOKEN=long-random-shared-secret
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# INFERENCE_GATEWAY_HOST=127.0.0.1
# INFERENCE_GATEWAY_PORT=8010

# --- Optional tools ---
FIRECRAWL_API_KEY=
# FAL_API_KEY=
# BUMBLEBEE_EXECUTION_RPC_URL=https://hands.example.com
# BUMBLEBEE_EXECUTION_RPC_TOKEN=
